<!-- Best Sellers Section -->
<div class="main-container" style="padding-top: 3rem; padding-bottom: 1rem;">

    <div class="bs-header">
        <div>
            <h2 class="bs-title">الأكثر مبيعاً</h2>
            <p class="bs-subtitle">أبرز المنتجات التي يختارها عملاؤنا</p>
        </div>
        <a href="/collections/all" class="btn-view-all">
            عرض الكل <i data-lucide="arrow-left"></i>
        </a>
    </div>

    <div class="bs-grid">

        <!-- Handbag -->
        <article class="bs-card">
            <span class="bs-badge">الأكثر مبيعاً</span>
            <img src="{{ 'bs-bag.jpg' | asset_url }}" alt="حقيبة يد فاخرة" class="bs-img" loading="eager">
            <div class="bs-card-overlay">
                <span class="bs-cat">حقائب نسائية</span>
                <h3 class="bs-name">حقيبة يد فاخرة</h3>
                <p class="bs-price">850 ر.ق</p>
                <a href="/collections/all" class="bs-btn">
                    عرض المنتج <i data-lucide="arrow-left"></i>
                </a>
            </div>
        </article>

        <!-- Perfume -->
        <article class="bs-card">
            <span class="bs-badge">الأكثر مبيعاً</span>
            <img src="{{ 'bs-perfume.jpg' | asset_url }}" alt="عطر فاخر" class="bs-img" loading="lazy">
            <div class="bs-card-overlay">
                <span class="bs-cat">عطور</span>
                <h3 class="bs-name">عطر لومينا الفاخر</h3>
                <p class="bs-price">650 ر.ق</p>
                <a href="/collections/all" class="bs-btn">
                    عرض المنتج <i data-lucide="arrow-left"></i>
                </a>
            </div>
        </article>

        <!-- Cap -->
        <article class="bs-card">
            <span class="bs-badge">الأكثر مبيعاً</span>
            <img src="{{ 'bs-cap.jpg' | asset_url }}" alt="كاب ديزاينر" class="bs-img" loading="lazy">
            <div class="bs-card-overlay">
                <span class="bs-cat">إكسسوارات</span>
                <h3 class="bs-name">كاب ديزاينر بريميوم</h3>
                <p class="bs-price">280 ر.ق</p>
                <a href="/collections/all" class="bs-btn">
                    عرض المنتج <i data-lucide="arrow-left"></i>
                </a>
            </div>
        </article>

        <!-- Shoes -->
        <article class="bs-card">
            <span class="bs-badge">الأكثر مبيعاً</span>
            <img src="{{ 'bs-shoes.jpg' | asset_url }}" alt="حذاء جلد فاخر" class="bs-img" loading="lazy">
            <div class="bs-card-overlay">
                <span class="bs-cat">أحذية</span>
                <h3 class="bs-name">حذاء جلد فاخر</h3>
                <p class="bs-price">920 ر.ق</p>
                <a href="/collections/all" class="bs-btn">
                    عرض المنتج <i data-lucide="arrow-left"></i>
                </a>
            </div>
        </article>

    </div>
</div>

{% section 'store-features' %}
{% section 'app-download' %}

<script>
    if (window.lucide) lucide.createIcons();
</script>
