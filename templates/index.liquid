<div class="main-container">
    
    <!-- Category Pills -->
    <section class="category-pills">
        <button class="pill active">الكل</button>
        {% for collection in collections %}
            {% if collection.handle != 'frontpage' %}
                <a href="{{ collection.url }}" class="pill" style="text-decoration: none;">{{ collection.title }}</a>
            {% endif %}
        {% endfor %}
        <!-- Fallbacks for visual layout if collections are empty -->
        {% if collections.size < 2 %}
            <button class="pill">أوفر سايز</button>
            <button class="pill">شورتات</button>
            <button class="pill">قمصان بحر</button>
            <button class="pill">مقاسات كبيرة</button>
            <button class="pill">أطقم</button>
            <button class="pill">هودي</button>
            <button class="pill">كابات</button>
            <button class="pill">جاكيت</button>
            <button class="pill">ساعات</button>
            <button class="pill">نظارات</button>
            <button class="pill">لابوبو</button>
        {% endif %}
    </section>

    <div class="content-wrapper">
        
        <!-- Sidebar Filters -->
        <aside class="sidebar-filters">
            <div class="filter-section">
                <div class="filter-header">
                    <h3>نطاق السعر</h3>
                    <button class="reset-btn">إعادة ضبط</button>
                </div>
                <p class="filter-desc">فلتر السعر غير مفعل في هذه النسخة</p>
                <div class="slider-container">
                    <div class="slider-track">
                        <div class="slider-fill"></div>
                        <div class="slider-thumb min"></div>
                        <div class="slider-thumb max"></div>
                    </div>
                    <div class="price-labels">
                        <span>20 ر.ق</span>
                        <span>1000 ر.ق</span>
                    </div>
                </div>
            </div>

            <div class="filter-section">
                <div class="filter-header">
                    <h3>الماركة</h3>
                    <button class="reset-btn">إعادة ضبط</button>
                </div>
                <div class="brand-list">
                    {% for product_vendor in shop.vendors limit: 5 %}
                        <label class="brand-item">
                            <input type="checkbox">
                            <span class="custom-checkbox">
                                <i data-lucide="check"></i>
                            </span>
                            <span class="brand-name">{{ product_vendor }}</span>
                        </label>
                    {% else %}
                        <label class="brand-item"><input type="checkbox" checked><span class="custom-checkbox"><i data-lucide="check"></i></span><span class="brand-name">أديداس</span></label>
                        <label class="brand-item"><input type="checkbox"><span class="custom-checkbox"><i data-lucide="check"></i></span><span class="brand-name">شوب فايف</span></label>
                        <label class="brand-item"><input type="checkbox"><span class="custom-checkbox"><i data-lucide="check"></i></span><span class="brand-name">نايك</span></label>
                    {% endfor %}
                </div>
            </div>
        </aside>

        <!-- Product Grid -->
        <div class="product-grid">
            {% assign main_collection = collections['frontpage'] %}
            {% if main_collection.products.size > 0 %}
                {% for product in main_collection.products %}
                    {% include 'product-card', product: product %}
                {% endfor %}
            {% else %}
                <!-- Static placeholders if no products exist yet in Shopify -->
                <article class="product-card">
                    <div class="card-image">
                        <button class="favorite-btn"><i data-lucide="heart"></i></button>
                        <img src="{{ 'oversized_tshirt_1781357964207.png' | asset_url }}" alt="أوفر سايز تي شيرت">
                        <span class="badge top-item">الأكثر مبيعاً</span>
                    </div>
                    <div class="card-content">
                        <h3 class="product-title">تيشيرت أوفر سايز قطن 100%</h3>
                        <div class="card-footer">
                            <div class="price-action">
                                <button class="add-cart-btn">
                                    <i data-lucide="shopping-cart"></i>
                                    <span>85.00 ر.ق</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </article>

                <article class="product-card">
                    <div class="card-image">
                        <button class="favorite-btn"><i data-lucide="heart"></i></button>
                        <img src="{{ 'cap_1781357980963.png' | asset_url }}" alt="كاب قطر">
                    </div>
                    <div class="card-content">
                        <h3 class="product-title">كاب قطر تصميم عصري</h3>
                        <div class="card-footer">
                            <div class="price-action">
                                <button class="add-cart-btn">
                                    <i data-lucide="shopping-cart"></i>
                                    <span>45.00 ر.ق</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </article>
                
                <article class="product-card">
                    <div class="card-image">
                        <button class="favorite-btn active"><i data-lucide="heart"></i></button>
                        <img src="{{ 'watch_1781357992251.png' | asset_url }}" alt="ساعة">
                        <div class="rating-badge"><span>4.8/5</span><i data-lucide="star"></i></div>
                    </div>
                    <div class="card-content">
                        <h3 class="product-title">ساعة رجالية فاخرة كلاسيك</h3>
                        <div class="card-footer">
                            <div class="price-action">
                                <span class="old-price">350.00 ر.ق</span>
                                <button class="add-cart-btn">
                                    <i data-lucide="shopping-cart"></i>
                                    <span>249.00 ر.ق</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </article>

                <article class="product-card">
                    <div class="card-image">
                        <button class="favorite-btn"><i data-lucide="heart"></i></button>
                        <img src="{{ 'labubu_1781358003607.png' | asset_url }}" alt="لابوبو">
                    </div>
                    <div class="card-content">
                        <h3 class="product-title">دمية لابوبو الإصدار المحدود</h3>
                        <div class="card-footer">
                            <div class="price-action">
                                <button class="add-cart-btn">
                                    <i data-lucide="shopping-cart"></i>
                                    <span>120.00 ر.ق</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </article>
            {% endif %}
        </div>

    </div>
</div>
