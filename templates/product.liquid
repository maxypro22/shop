<div class="main-container" style="padding-top: 2rem;">
    
    <div class="product-layout">
        <!-- Gallery -->
        <div class="product-gallery">
            <div class="main-image-container">
                <img id="MainProductImage" src="{{ product.featured_image | img_url: '800x' }}" alt="{{ product.title | escape }}">
            </div>
            {% if product.media.size > 1 %}
            <div class="thumbnail-list">
                {% for media in product.media %}
                    <img src="{{ media | img_url: '200x' }}" alt="{{ media.alt | escape }}" class="thumbnail {% if forloop.first %}active{% endif %}" onclick="changeMainImage(this, '{{ media | img_url: '800x' }}')">
                {% endfor %}
            </div>
            {% endif %}
        </div>

        <!-- Details -->
        <div class="product-info">
            <h1 class="product-title-large">{{ product.title }}</h1>
            <div class="product-price-large">
                <span id="ProductPrice">{{ product.price | money }}</span>
                {% if product.compare_at_price > product.price %}
                    <span id="ComparePrice" class="old-price-large">{{ product.compare_at_price | money }}</span>
                {% endif %}
            </div>

            {% form 'product', product, id: 'AddToCartForm', class: 'product-form' %}
                <!-- Variants -->
                {% unless product.has_only_default_variant %}
                    {% for option in product.options_with_values %}
                        <div class="variant-selector">
                            <label class="variant-label">{{ option.name }}</label>
                            <div class="variant-pills">
                                {% for value in option.values %}
                                    <input type="radio" name="option-{{ option.position }}" id="Option-{{ option.position }}-{{ forloop.index0 }}" value="{{ value | escape }}" {% if option.selected_value == value %}checked{% endif %} class="variant-radio" onchange="updateVariantSelection()">
                                    <label for="Option-{{ option.position }}-{{ forloop.index0 }}" class="variant-pill">{{ value }}</label>
                                {% endfor %}
                            </div>
                        </div>
                    {% endfor %}
                {% endunless %}

                <!-- Hidden Master Select -->
                <select name="id" id="ProductSelect" style="display: none;">
                    {% for variant in product.variants %}
                        <option value="{{ variant.id }}" data-price="{{ variant.price | money }}" data-compare="{{ variant.compare_at_price | money }}" data-available="{{ variant.available }}" data-options='{{ variant.options | json }}'>
                            {{ variant.title }}
                        </option>
                    {% endfor %}
                </select>

                <!-- Quantity -->
                <div class="quantity-selector">
                    <label class="variant-label">الكمية</label>
                    <div class="qty-input-wrapper">
                        <button type="button" class="qty-btn" onclick="adjustQty(-1)" aria-label="تقليل">&#8722;</button>
                        <input type="number" id="Quantity" name="quantity" value="1" min="1" class="qty-input" readonly>
                        <button type="button" class="qty-btn" onclick="adjustQty(1)" aria-label="زيادة">&#43;</button>
                    </div>
                </div>

                <!-- Buttons -->
                <div class="product-actions">
                    <button type="submit" name="add" id="AddToCart" class="add-cart-btn-large" {% unless product.available %}disabled{% endunless %}>
                        <i data-lucide="shopping-cart"></i>
                        <span id="AddToCartText">
                            {% if product.available %}إضافة إلى السلة{% else %}نفدت الكمية{% endif %}
                        </span>
                    </button>
                    <button type="button" class="buy-now-btn" onclick="buyNow()" {% unless product.available %}disabled{% endunless %}>
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                        اشتري الآن
                    </button>
                </div>
            {% endform %}

            <div class="product-description-full">
                <h3>وصف المنتج</h3>
                <div class="rte">
                    {{ product.description }}
                </div>
            </div>
        </div>
    </div>

    <!-- Recently Viewed -->
    <div id="recently-viewed-section" class="related-products" style="display:none;">
        <h2 class="section-title">شاهدت مؤخراً</h2>
        <div class="product-grid" id="recently-viewed-grid"></div>
    </div>

    <!-- Related Products -->
    {% assign current_product = product %}
    {% assign related_collection = product.collections.first %}

    {% if related_collection and related_collection.products_count > 1 %}
    <div class="related-products">
        <h2 class="section-title">قد يعجبك أيضاً</h2>
        <div class="product-grid">
            {% assign counter = 0 %}
            {% for rel_product in related_collection.products %}
                {% if rel_product.handle != current_product.handle and counter < 4 %}
                    {% render 'product-card', product: rel_product %}
                    {% assign counter = counter | plus: 1 %}
                {% endif %}
            {% endfor %}
        </div>
    </div>
    {% endif %}

</div>

<script>
    // Buy Now — adds to cart via AJAX then redirects to checkout
    function buyNow() {
        var form  = document.getElementById('AddToCartForm');
        var btn   = document.querySelector('.buy-now-btn');
        if (!form || !btn) return;
        btn.disabled = true;
        btn.innerHTML = '<span style="opacity:.7">جاري...</span>';
        var data = new FormData(form);
        fetch('/cart/add.js', { method: 'POST', body: data })
            .then(function() { window.location.href = '/checkout'; })
            .catch(function() { form.submit(); });
    }

    // Pass product options array to JS
    window.productVariants = {{ product.variants | json }};

    // Recently Viewed
    (function() {
        var STORAGE_KEY = 'rv_products';
        var CURRENCY    = 'ر.ق'; // ر.ق

        var current = {
            handle: {{ product.handle | json }},
            title:  {{ product.title | json }},
            cents:  {{ product.price }},
            image:  {{ product.featured_image.src | img_url: '600x600', crop: 'center' | json }},
            url:    {{ product.url | json }}
        };

        // Load, dedupe, prepend current, trim
        var viewed = [];
        try { viewed = JSON.parse(localStorage.getItem(STORAGE_KEY) || '[]'); } catch(e) {}
        viewed = viewed.filter(function(p) { return p.handle !== current.handle; });
        viewed.unshift(current);
        if (viewed.length > 8) viewed = viewed.slice(0, 8);
        try { localStorage.setItem(STORAGE_KEY, JSON.stringify(viewed)); } catch(e) {}

        // Render (skip current product)
        var toShow = viewed.filter(function(p) { return p.handle !== current.handle; }).slice(0, 4);
        if (toShow.length === 0) return;

        var section = document.getElementById('recently-viewed-section');
        var grid    = document.getElementById('recently-viewed-grid');
        if (!section || !grid) return;

        toShow.forEach(function(p) {
            var price = (p.cents / 100).toFixed(2) + ' ' + CURRENCY;
            var card  = document.createElement('article');
            card.className = 'product-card';
            card.innerHTML =
                '<div class="card-image">' +
                    '<a href="' + p.url + '" class="product-image-link">' +
                        '<img src="' + p.image + '" alt="' + p.title.replace(/"/g, '&quot;') + '" loading="lazy" class="primary-image">' +
                    '</a>' +
                '</div>' +
                '<div class="card-content">' +
                    '<a href="' + p.url + '" style="text-decoration:none;color:inherit;flex:1;">' +
                        '<h3 class="product-title">' + p.title + '</h3>' +
                    '</a>' +
                    '<div class="product-price-wrapper" style="margin-bottom:1rem;font-weight:800;color:var(--primary);">' +
                        '<span>' + price + '</span>' +
                    '</div>' +
                    '<div class="card-footer">' +
                        '<div class="card-actions-grid">' +
                            '<a href="' + p.url + '" class="btn-action view-product" style="flex:1;">' +
                                '<span>عرض المنتج</span>' +
                            '</a>' +
                        '</div>' +
                    '</div>' +
                '</div>';
            grid.appendChild(card);
        });

        section.style.display = 'block';
        if (window.lucide) lucide.createIcons();
    })();
</script>
