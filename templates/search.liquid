<div class="main-container" style="padding-top: 2rem;">

    {%- if search.performed -%}

        <!-- Search Header -->
        <div class="search-results-header">
            {%- if search.results_count == 0 -%}
                <h1 class="search-title">لا توجد نتائج لـ "<span class="search-term">{{ search.terms | escape }}</span>"</h1>
                <p class="search-sub">جرّب كلمات أخرى أو تصفّح المجموعات</p>
            {%- else -%}
                <h1 class="search-title">نتائج البحث عن "<span class="search-term">{{ search.terms | escape }}</span>"</h1>
                <p class="search-sub">{{ search.results_count }} منتج وجدناه لك</p>
            {%- endif -%}
        </div>

        {%- if search.results_count > 0 -%}
            <!-- Product Grid -->
            <div class="product-grid" style="margin-top: 2rem;">
                {%- for item in search.results -%}
                    {%- if item.object_type == 'product' -%}
                        {% assign product = item %}
                        {% render 'product-card', product: product %}
                    {%- endif -%}
                {%- endfor -%}
            </div>

            <!-- Pagination -->
            {%- if paginate.pages > 1 -%}
                <div class="pagination" style="margin-top: 3rem; display: flex; justify-content: center; gap: 0.5rem;">
                    {%- if paginate.previous -%}
                        <a href="{{ paginate.previous.url }}" class="page-btn">السابق</a>
                    {%- endif -%}
                    {%- for part in paginate.parts -%}
                        {%- if part.is_link -%}
                            <a href="{{ part.url }}" class="page-btn">{{ part.title }}</a>
                        {%- else -%}
                            <span class="page-btn active">{{ part.title }}</span>
                        {%- endif -%}
                    {%- endfor -%}
                    {%- if paginate.next -%}
                        <a href="{{ paginate.next.url }}" class="page-btn">التالي</a>
                    {%- endif -%}
                </div>
            {%- endif -%}

        {%- else -%}
            <!-- Empty State -->
            <div class="empty-search" style="text-align: center; padding: 4rem 2rem;">
                <div style="font-size: 5rem; margin-bottom: 1.5rem;">🔍</div>
                <p style="color: var(--text-muted); font-size: 1.1rem; margin-bottom: 2rem;">لم نجد منتجات تطابق بحثك. جرّب كلمات أخرى!</p>
                <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
                    <a href="/collections/العطور" class="pill">العطور</a>
                    <a href="/collections/shoes" class="pill">shoes</a>
                    <a href="/collections/t-shirt" class="pill">t-shirt</a>
                    <a href="/collections/قمصان-رجالية" class="pill">قمصان رجالية</a>
                    <a href="/collections/oversized" class="pill">oversized</a>
                    <a href="/collections/سليبر-بحر" class="pill">سليبر بحر</a>
                </div>
            </div>
        {%- endif -%}

    {%- else -%}
        <!-- No search performed yet -->
        <div style="text-align: center; padding: 4rem 2rem;">
            <h2 style="margin-bottom: 1rem;">ابحث عن منتجاتك المفضلة</h2>
            <p style="color: var(--text-muted);">استخدم شريط البحث أعلى الصفحة</p>
        </div>
    {%- endif -%}

</div>

<style>
.search-results-header {
    padding: 1rem 0 2rem;
    border-bottom: 1px solid var(--border-color);
    margin-bottom: 1rem;
}

.search-title {
    font-size: 1.75rem;
    font-weight: 800;
    color: var(--text-dark);
    margin-bottom: 0.5rem;
}

.search-term {
    color: var(--primary);
}

.search-sub {
    color: var(--text-muted);
    font-size: 1rem;
}

.page-btn {
    padding: 0.5rem 1rem;
    border-radius: var(--radius-full);
    border: 1px solid var(--border-color);
    background: var(--bg-card);
    color: var(--text-dark);
    font-weight: 600;
    font-size: 0.9rem;
    text-decoration: none;
    transition: var(--transition);
}

.page-btn:hover {
    border-color: var(--primary);
    color: var(--primary);
}

.page-btn.active {
    background: var(--primary);
    color: white;
    border-color: var(--primary);
}
</style>
