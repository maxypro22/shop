<article class="product-card">
    <div class="card-image">
        <button class="favorite-btn" onclick="event.preventDefault();">
            <i data-lucide="heart"></i>
        </button>
        <a href="{{ product.url | within: collection }}" class="product-image-link {% if product.images.size > 1 %}has-hover-image{% endif %}">
            <img src="{{ product.featured_image.src | img_url: '600x600', crop: 'center' }}"
                 alt="{{ product.featured_image.alt | escape }}"
                 class="primary-image"
                 loading="lazy"
                 decoding="async"
                 width="600" height="600">
            {% if product.images.size > 1 %}
                <img src="{{ product.images[1].src | img_url: '600x600', crop: 'center' }}"
                     alt="{{ product.images[1].alt | escape }}"
                     class="secondary-image"
                     loading="lazy"
                     decoding="async"
                     width="600" height="600">
            {% endif %}
        </a>
        {% if product.tags contains 'top' %}
            <span class="badge top-item">الأكثر مبيعاً</span>
        {% endif %}
        {% if product.compare_at_price > product.price %}
            {% assign discount_pct = product.compare_at_price | minus: product.price | times: 100 | divided_by: product.compare_at_price %}
            <span class="badge sale-badge">-{{ discount_pct }}%</span>
        {% endif %}
    </div>
    <div class="card-content">
        {%- assign total_stock = 0 -%}
        {%- for v in product.variants -%}
            {%- if v.inventory_quantity > 0 -%}
                {%- assign total_stock = total_stock | plus: v.inventory_quantity -%}
            {%- endif -%}
        {%- endfor -%}
        {%- if product.variants.first.inventory_management == 'shopify' -%}
            {%- if total_stock <= 0 -%}
                <div class="stock-pill stock-out"><span class="stock-dot"></span>نفدت الكمية</div>
            {%- elsif total_stock <= 5 -%}
                <div class="stock-pill stock-urgent"><span class="stock-dot"></span>آخر {{ total_stock }} قطع فقط</div>
            {%- elsif total_stock <= 15 -%}
                <div class="stock-pill stock-low"><span class="stock-dot"></span>{{ total_stock }} متبقية</div>
            {%- endif -%}
        {%- endif -%}
        <a href="{{ product.url | within: collection }}" style="text-decoration: none; color: inherit;">
            <h3 class="product-title">{{ product.title }}</h3>
        </a>
        <div class="product-price-wrapper" style="margin-top: auto; margin-bottom: 1rem; font-weight: 800; color: var(--primary); display: flex; align-items: center; gap: 0.5rem;">
            <span>{{ product.price | money }}</span>
            {% if product.compare_at_price > product.price %}
                <span class="old-price" style="font-weight: normal; font-size: 0.85rem; text-decoration: line-through; color: var(--text-light);">{{ product.compare_at_price | money }}</span>
            {% endif %}
        </div>
        <div class="card-footer">
            <div class="card-actions-grid">
                <form action="/cart/add" method="post" enctype="multipart/form-data" class="add-to-cart-form" style="flex: 1;">
                    <input type="hidden" name="id" value="{{ product.variants.first.id }}">
                    <button type="submit" class="btn-action add-cart" style="width: 100%;">
                        <i data-lucide="shopping-cart"></i>
                        <span>للسلة</span>
                    </button>
                </form>
                <a href="{{ product.url | within: collection }}" class="btn-action view-product" style="flex: 1;">
                    <i data-lucide="eye"></i>
                    <span>عرض</span>
                </a>
            </div>
        </div>
    </div>
</article>
