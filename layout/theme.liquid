<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ page_title }} | {{ shop.name }}</title>
    
    {% if page_description %}
        <meta name="description" content="{{ page_description | escape }}">
    {% endif %}

    <!-- Meta -->
    <meta name="theme-color" content="#0f172a">

    <!-- DNS prefetch for external origins -->
    <link rel="dns-prefetch" href="https://fonts.googleapis.com">
    <link rel="dns-prefetch" href="https://unpkg.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <!-- Critical font — preload woff2 subset hint -->
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;700;800&display=swap" rel="stylesheet">

    {% if template == 'index' %}
    <!-- Preload LCP hero image -->
    <link rel="preload" as="image" href="{{ 'hero-image.jpg' | asset_url }}" fetchpriority="high">
    {% endif %}

    <!-- Theme CSS -->
    {{ 'styles.css' | asset_url | stylesheet_tag }}

    <!-- Required Shopify Scripts -->
    {{ content_for_header }}
</head>
<body>

    <div style="position: sticky; top: 0; z-index: 50; background-color: rgba(255, 255, 255, 0.85); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid var(--border-color);">
        {% section 'header' %}
    </div>

    {% if template == 'index' %}
        {% section 'hero-video' %}
    {% endif %}

    <div style="position: relative; z-index: 1; background-color: rgba(255, 255, 255, 0.97); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid var(--border-color); box-shadow: 0 -2px 32px rgba(0,0,0,0.10); border-radius: 2rem 2rem 0 0; overflow: hidden; {% if template == 'index' %}margin-top: -2rem;{% endif %}">
        {% section 'category-pills' %}
    </div>

    <main role="main" id="MainContent" style="position: relative; z-index: 1;">
        {{ content_for_layout }}
    </main>

    <!-- Footer -->
    {% section 'footer' %}

    <!-- Lucide icons — defer so it never blocks render; onload fires icons immediately -->
    <script src="https://unpkg.com/lucide@0.468.0/dist/umd/lucide.min.js" defer onload="lucide.createIcons()"></script>

    <!-- Theme JS -->
    {{ 'script.js' | asset_url | script_tag }}
</body>
</html>
