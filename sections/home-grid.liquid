<div class="product-grid">
    {% if section.settings.collection != blank %}
        {% for product in collections[section.settings.collection].products %}
            {% render 'product-card', product: product %}
        {% endfor %}
    {% else %}
        {% for block in section.blocks %}
            <article class="product-card" {{ block.shopify_attributes }}>
                <a href="{{ block.settings.link | default: '#' }}" style="text-decoration: none; color: inherit; display: flex; flex-direction: column; height: 100%;">
                    <div class="card-image" style="aspect-ratio: 1; overflow: hidden; display: flex; align-items: center; justify-content: center; background: #f1f5f9;">
                        <button class="favorite-btn" onclick="event.preventDefault();"><i data-lucide="heart"></i></button>
                        {% if block.settings.image != blank %}
                            <img src="{{ block.settings.image | img_url: '600x600', crop: 'center' }}" alt="{{ block.settings.title }}" style="width: 100%; height: 100%; object-fit: cover;">
                        {% else %}
                            <img src="{{ 'oversized_tshirt_1781357964207.png' | asset_url }}" style="width: 100%; height: 100%; object-fit: cover;">
                        {% endif %}
                    </div>
                    <div class="card-content" style="flex: 1; display: flex; flex-direction: column; justify-content: space-between;">
                        <h3 class="product-title" style="margin-bottom: 1rem;">{{ block.settings.title | default: 'عنوان المنتج' }}</h3>
                        <div class="card-footer">
                            <div class="price-action">
                                <button class="add-cart-btn" onclick="event.preventDefault();">
                                    <i data-lucide="shopping-cart"></i>
                                    <span>{{ block.settings.price | default: '85.00 ر.ق' }}</span>
                                </button>
                            </div>
                        </div>
                    </div>
                </a>
            </article>
        {% endfor %}
    {% endif %}
</div>

{% schema %}
{
  "name": "المنتجات في الرئيسية",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "اختر مجموعة المنتجات (إن أردت جلبها تلقائياً)"
    },
    {
      "type": "paragraph",
      "content": "ملاحظة: إذا لم تختر مجموعة بالأعلى، سيتم عرض الصور والمنتجات التي تضيفها يدوياً بالأسفل."
    }
  ],
  "blocks": [
    {
      "type": "custom_card",
      "name": "بطاقة منتج يدوية",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "صورة المنتج (سيتم ضبطها بشكل مربع تلقائياً)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "اسم المنتج",
          "default": "تيشيرت أوفر سايز"
        },
        {
          "type": "text",
          "id": "price",
          "label": "السعر",
          "default": "85.00 ر.ق"
        },
        {
          "type": "url",
          "id": "link",
          "label": "الرابط عند الضغط"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "شبكة المنتجات",
      "blocks": [
        { "type": "custom_card" },
        { "type": "custom_card" },
        { "type": "custom_card" },
        { "type": "custom_card" }
      ]
    }
  ]
}
{% endschema %}
