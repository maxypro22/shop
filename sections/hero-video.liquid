<!-- Scroll zone: sticky hero + rising cover panel -->
<div class="hero-zone" id="HeroZone">
<div class="hero-section" id="HeroSection">

    <!-- Full-bleed image -->
    <img
        id="HeroImage"
        src="{{ 'hero-image.jpg' | asset_url }}"
        alt="Shop Five"
        class="hero-img"
        loading="eager"
        fetchpriority="high"
    >

    <!-- Gradient overlay -->
    <div class="hero-overlay"></div>

    <!-- Film grain -->
    <div class="hero-grain"></div>

    <!-- Optional text (from theme editor) -->
    {% if section.settings.show_overlay %}
    <div class="hero-content" id="HeroContent">
        {% if section.settings.title != blank %}
            <h2 class="hero-title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
            <p class="hero-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
        {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
            <a href="{{ section.settings.btn_link }}" class="hero-cta">
                {{ section.settings.btn_text }}
                <i data-lucide="arrow-left" style="width:18px;height:18px;display:inline-block;vertical-align:middle;margin-right:6px;"></i>
            </a>
        {% endif %}
    </div>
    {% endif %}

    <!-- Scroll hint -->
    <div class="hero-scroll-hint" id="HeroScrollHint">
        <i data-lucide="chevrons-down"></i>
    </div>

    <!-- Rising cover panel — slides up over the image on scroll -->
    <div class="hero-cover" id="HeroCover"></div>

</div>
</div>

<style>
/* ── Scroll zone ─────────────────────────────────────────── */
.hero-zone {
    height: 190vh;      /* extra height creates the scroll travel */
    position: relative;
}

/* ── Sticky hero ─────────────────────────────────────────── */
.hero-section {
    position: sticky;
    top: 0;
    height: 100vh;
    min-height: 560px;
    overflow: hidden;
    background: #07090f;
    will-change: transform;
}

/* ── Hero image ──────────────────────────────────────────── */
.hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 112%;
    top: -6%;
    object-fit: cover;
    object-position: center top;
    will-change: transform;
    animation: hero-breathe 14s ease-in-out infinite alternate;
}
@keyframes hero-breathe {
    0%   { transform: scale(1.00); }
    100% { transform: scale(1.06); }
}
.hero-img.js-parallax { animation-play-state: paused; }

/* ── Overlays ────────────────────────────────────────────── */
.hero-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background:
        radial-gradient(ellipse at center, transparent 40%, rgba(5,7,15,0.5) 100%),
        linear-gradient(to top, rgba(5,7,15,0.65) 0%, transparent 50%);
}
.hero-grain {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    mix-blend-mode: overlay;
    background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><filter id="n"><feTurbulence type="fractalNoise" baseFrequency="0.72" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%25" height="100%25" filter="url(%23n)" opacity="0.055"/></svg>');
}

/* ── Text content ────────────────────────────────────────── */
.hero-content {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    padding: 3rem;
    gap: 1.25rem;
    pointer-events: none;
}
.hero-title {
    font-size: clamp(1.6rem, 4vw, 3.2rem);
    font-weight: 900;
    color: #fff;
    text-shadow: 0 2px 16px rgba(0,0,0,0.5);
    text-align: right;
    pointer-events: auto;
}
.hero-subtitle {
    font-size: clamp(0.9rem, 1.5vw, 1.2rem);
    color: rgba(255,255,255,0.82);
    text-align: right;
    max-width: 400px;
    pointer-events: auto;
}
.hero-cta {
    display: inline-flex;
    align-items: center;
    background: #fff;
    color: var(--text-dark);
    font-weight: 800;
    font-size: 1rem;
    padding: 0.85rem 2rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: var(--transition);
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    pointer-events: auto;
}
.hero-cta:hover { background: var(--primary); color: #fff; transform: translateY(-2px); }

/* ── Scroll hint ─────────────────────────────────────────── */
.hero-scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.6);
    z-index: 5;
    transition: opacity 0.5s ease;
    animation: hint-bounce 2s ease-in-out infinite;
}
.hero-scroll-hint i,
.hero-scroll-hint svg { width: 34px; height: 34px; }
@keyframes hint-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0);    opacity: 0.6; }
    50%       { transform: translateX(-50%) translateY(10px); opacity: 1;   }
}

/* ── Rising cover panel ──────────────────────────────────── */
.hero-cover {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;       /* slight overlap prevents sub-pixel gap */
    height: 100%;
    background: var(--bg-main);
    border-radius: 28px 28px 0 0;
    transform: translateY(100%); /* starts fully below viewport */
    will-change: transform;
    z-index: 9;
    /* shadow on top edge creates depth as it rises */
    box-shadow: 0 -16px 60px rgba(0,0,0,0.22);
}

/* ── Mobile ──────────────────────────────────────────────── */
@media (max-width: 768px) {
    .hero-zone { height: 170vh; }
    .hero-content {
        padding: 1.5rem 1.5rem 5rem;
        align-items: center;
        justify-content: flex-end;
    }
    .hero-subtitle { max-width: 100%; }
    .hero-cover { border-radius: 20px 20px 0 0; }
}
</style>

<script>
(function () {
    var img   = document.getElementById('HeroImage');
    var cover = document.getElementById('HeroCover');
    var hint  = document.getElementById('HeroScrollHint');
    var zone  = document.getElementById('HeroZone');
    if (!img || !cover || !zone) return;

    var ticking = false;

    /* smooth-step easing: slow start, slow end */
    function smoothStep(t) {
        return t * t * (3 - 2 * t);
    }

    function update() {
        ticking = false;
        var scrolled  = window.scrollY;
        var viewH     = window.innerHeight;

        /* Progress 0 → 1 over the first 80vh of scroll */
        var raw      = Math.max(0, Math.min(1, scrolled / (viewH * 0.80)));
        var progress = smoothStep(raw);

        /* Cover rises from translateY(100%) → translateY(0%) */
        cover.style.transform = 'translateY(' + ((1 - progress) * 100) + '%)';

        /* Image gentle parallax: shifts up slightly as cover rises */
        var imgShift = -progress * 7;  /* -7% max upward shift */
        img.style.transform = 'scale(1.06) translateY(' + imgShift + '%)';
        img.classList.add('js-parallax');

        /* Fade hint early */
        if (hint) hint.style.opacity = raw > 0.08 ? '0' : '1';
    }

    function onScroll() {
        if (!ticking) { requestAnimationFrame(update); ticking = true; }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    update();
})();
</script>

{% schema %}
{
  "name": "هيرو",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "إظهار نص فوق الصورة",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "العنوان الرئيسي",
      "default": "الجديد في Shop Five"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "النص الفرعي",
      "default": "اكتشف أحدث التصاميم لهذا الموسم"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "نص الزر"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "رابط الزر"
    }
  ],
  "presets": [{ "name": "هيرو" }]
}
{% endschema %}
