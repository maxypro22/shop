<div id="hero-scroll-zone" class="hero-scroll-zone">
    <div class="hero-canvas-sticky">

        <canvas id="HeroCanvas" class="hero-canvas"></canvas>

        {% if section.settings.show_overlay %}
        <div class="hero-video-overlay">
            {% if section.settings.title != blank %}
                <h2 class="hero-video-title">{{ section.settings.title }}</h2>
            {% endif %}
            {% if section.settings.subtitle != blank %}
                <p class="hero-video-subtitle">{{ section.settings.subtitle }}</p>
            {% endif %}
            {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
                <a href="{{ section.settings.btn_link }}" class="hero-video-btn">
                    {{ section.settings.btn_text }}
                    <i data-lucide="arrow-left" style="width:18px;height:18px;display:inline-block;vertical-align:middle;margin-right:6px;"></i>
                </a>
            {% endif %}
        </div>
        {% endif %}

        <div class="hero-scroll-hint">
            <i data-lucide="chevrons-down"></i>
        </div>

    </div>
</div>

<script>
window.heroFrameUrls = [
  {% for i in (1..48) %}
    {% assign padded = i | prepend: '000' | slice: -3, 3 %}
    {% assign fname = 'seq-' | append: padded | append: '.jpg' %}
    {{ fname | asset_url | json }}{% unless forloop.last %},{% endunless %}
  {% endfor %}
];
</script>

<script>
(function () {
    var FRAME_COUNT = 48;
    var urls        = window.heroFrameUrls || [];
    var images      = new Array(FRAME_COUNT);
    var ready       = new Array(FRAME_COUNT).fill(false);
    var canvas      = document.getElementById('HeroCanvas');
    var ctx         = canvas.getContext('2d');
    var zone        = document.getElementById('hero-scroll-zone');
    var currentIdx  = 0;
    var raf         = null;

    /* ── resize canvas to its CSS size ───────────────────────── */
    function resize() {
        canvas.width  = canvas.offsetWidth;
        canvas.height = canvas.offsetHeight;
        draw(currentIdx);
    }

    /* ── draw a single frame, cover-fit ──────────────────────── */
    function draw(idx) {
        if (!ready[idx]) return;
        var img = images[idx];
        var cw  = canvas.width,  ch  = canvas.height;
        var iw  = img.naturalWidth || img.width;
        var ih  = img.naturalHeight || img.height;
        if (!iw || !ih) return;
        var scale = Math.max(cw / iw, ch / ih);
        var nw = iw * scale, nh = ih * scale;
        var nx = (cw - nw) / 2,  ny = (ch - nh) / 2;
        ctx.clearRect(0, 0, cw, ch);
        ctx.drawImage(img, nx, ny, nw, nh);
        currentIdx = idx;
    }

    /* ── scroll → frame index ─────────────────────────────────── */
    function getFrame() {
        var rect        = zone.getBoundingClientRect();
        var scrolled    = -rect.top;
        var totalScroll = zone.offsetHeight - window.innerHeight;
        if (totalScroll <= 0) return 0;
        var progress = Math.max(0, Math.min(1, scrolled / totalScroll));
        return Math.round(progress * (FRAME_COUNT - 1));
    }

    function onScroll() {
        if (raf) return;
        raf = requestAnimationFrame(function () {
            draw(getFrame());
            raf = null;
        });
    }

    /* ── preload all frames ───────────────────────────────────── */
    function load(i) {
        var img = new Image();
        img.onload = function () {
            ready[i] = true;
            if (i === 0) { resize(); }
        };
        img.src    = urls[i];
        images[i]  = img;
    }

    /* load first frame right away, rest in order */
    load(0);
    for (var i = 1; i < FRAME_COUNT; i++) { load(i); }

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', resize);
    resize();
})();
</script>

<style>
.hero-scroll-zone {
    height: 220vh;
    position: relative;
}

.hero-canvas-sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    width: 100%;
    overflow: hidden;
    background: #000;
}

.hero-canvas {
    display: block;
    width: 100%;
    height: 100%;
}

/* keep overlay & effects from original */
.hero-video-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle, transparent 50%, rgba(0,0,0,0.55) 150%);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-end;
    padding: 3rem;
    gap: 1rem;
    z-index: 2;
    pointer-events: none;
}

.hero-canvas-sticky::after {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><filter id="n"><feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%25" height="100%25" filter="url(%23n)" opacity="0.07"/></svg>');
    pointer-events: none;
    z-index: 1;
}

.hero-video-title {
    font-size: clamp(1.5rem, 4vw, 3rem);
    font-weight: 900;
    color: white;
    text-shadow: 0 2px 12px rgba(0,0,0,0.4);
    text-align: right;
    pointer-events: auto;
}

.hero-video-subtitle {
    font-size: clamp(0.9rem, 1.5vw, 1.2rem);
    color: rgba(255,255,255,0.85);
    text-align: right;
    max-width: 400px;
    pointer-events: auto;
}

.hero-video-btn {
    display: inline-flex;
    align-items: center;
    background-color: white;
    color: var(--text-dark);
    font-weight: 800;
    font-size: 1rem;
    padding: 0.85rem 2rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: var(--transition);
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    pointer-events: auto;
}

.hero-video-btn:hover {
    background-color: var(--primary);
    color: white;
    transform: translateY(-2px);
}

/* scroll hint arrow */
.hero-scroll-hint {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.6);
    z-index: 3;
    animation: hint-bounce 1.8s ease-in-out infinite;
}

.hero-scroll-hint i { width: 32px; height: 32px; }

@keyframes hint-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0);   opacity: 0.6; }
    50%       { transform: translateX(-50%) translateY(8px); opacity: 1;   }
}

@media (max-width: 768px) {
    .hero-scroll-zone { height: 200vh; }
    .hero-video-overlay {
        padding: 1.5rem;
        align-items: center;
        text-align: center;
        background: linear-gradient(to top, rgba(0,0,0,0.6) 0%, transparent 60%);
        justify-content: flex-end;
    }
    .hero-video-subtitle { max-width: 100%; }
}
</style>

{% schema %}
{
  "name": "فيديو البطل",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "إظهار نص فوق الفيديو",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "العنوان الرئيسي",
      "default": "الجديد في Shop Five"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "النص الفرعي",
      "default": "اكتشف أحدث التصاميم لهذا الموسم"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "نص الزر"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "رابط الزر"
    }
  ],
  "presets": [
    {
      "name": "فيديو البطل"
    }
  ]
}
{% endschema %}
