<div class="hero-section" id="HeroSection">

    <!-- Full-bleed hero image -->
    <img
        id="HeroImage"
        src="{{ 'hero-image.jpg' | asset_url }}"
        alt="Shop Five"
        class="hero-img"
        loading="eager"
        fetchpriority="high"
    >

    <!-- Dark gradient overlay for readability -->
    <div class="hero-overlay"></div>

    <!-- Optional text overlay (controlled from theme editor) -->
    {% if section.settings.show_overlay %}
    <div class="hero-content">
        {% if section.settings.title != blank %}
            <h2 class="hero-title">{{ section.settings.title }}</h2>
        {% endif %}
        {% if section.settings.subtitle != blank %}
            <p class="hero-subtitle">{{ section.settings.subtitle }}</p>
        {% endif %}
        {% if section.settings.btn_text != blank and section.settings.btn_link != blank %}
            <a href="{{ section.settings.btn_link }}" class="hero-cta">
                {{ section.settings.btn_text }}
                <i data-lucide="arrow-left" style="width:18px;height:18px;display:inline-block;vertical-align:middle;margin-right:6px;"></i>
            </a>
        {% endif %}
    </div>
    {% endif %}

    <!-- Scroll hint -->
    <div class="hero-scroll-hint" id="HeroScrollHint">
        <i data-lucide="chevrons-down"></i>
    </div>

    <!-- Film grain -->
    <div class="hero-grain"></div>

</div>

<style>
/* ── Hero section ──────────────────────────────────────────── */
.hero-section {
    position: relative;
    width: 100%;
    height: 100vh;
    min-height: 560px;
    overflow: hidden;
    background: #07090f;
}

/* Image fills section; JS drives a subtle parallax translateY */
.hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 115%;   /* extra height so parallax has room */
    top: -7.5%;
    object-fit: cover;
    object-position: center top;
    will-change: transform;
    animation: hero-ken-burns 14s ease-in-out infinite alternate;
}

/* Slow zoom breathe (Ken Burns) */
@keyframes hero-ken-burns {
    0%   { transform: scale(1.00) translateY(0); }
    100% { transform: scale(1.07) translateY(-1%); }
}

/* When JS parallax is active, animation still adds on top */
.hero-img.parallax-active {
    animation-play-state: paused; /* JS takes over motion */
}

/* Gradient overlay — dark bottom + vignette edges */
.hero-overlay {
    position: absolute;
    inset: 0;
    background:
        radial-gradient(ellipse at center, transparent 45%, rgba(5,7,15,0.55) 100%),
        linear-gradient(to top, rgba(5,7,15,0.72) 0%, transparent 55%);
    z-index: 2;
    pointer-events: none;
}

/* Film-grain texture */
.hero-grain {
    position: absolute;
    inset: 0;
    z-index: 3;
    pointer-events: none;
    background-image: url('data:image/svg+xml;utf8,<svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg"><filter id="n"><feTurbulence type="fractalNoise" baseFrequency="0.72" numOctaves="3" stitchTiles="stitch"/></filter><rect width="100%25" height="100%25" filter="url(%23n)" opacity="0.055"/></svg>');
    mix-blend-mode: overlay;
}

/* Text overlay */
.hero-content {
    position: absolute;
    inset: 0;
    z-index: 4;
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: center;
    padding: 3rem;
    gap: 1.25rem;
    pointer-events: none;
}
.hero-title {
    font-size: clamp(1.6rem, 4vw, 3.2rem);
    font-weight: 900;
    color: #fff;
    text-shadow: 0 2px 16px rgba(0,0,0,0.45);
    text-align: right;
    pointer-events: auto;
}
.hero-subtitle {
    font-size: clamp(0.9rem, 1.5vw, 1.2rem);
    color: rgba(255,255,255,0.82);
    text-align: right;
    max-width: 400px;
    pointer-events: auto;
}
.hero-cta {
    display: inline-flex;
    align-items: center;
    background: #fff;
    color: var(--text-dark);
    font-weight: 800;
    font-size: 1rem;
    padding: 0.85rem 2rem;
    border-radius: var(--radius-full);
    text-decoration: none;
    transition: var(--transition);
    box-shadow: 0 4px 20px rgba(0,0,0,0.3);
    pointer-events: auto;
}
.hero-cta:hover {
    background: var(--primary);
    color: #fff;
    transform: translateY(-2px);
}

/* Scroll hint */
.hero-scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255,255,255,0.6);
    z-index: 5;
    transition: opacity 0.5s ease;
    animation: hint-bounce 2s ease-in-out infinite;
}
.hero-scroll-hint i,
.hero-scroll-hint svg { width: 34px; height: 34px; }

@keyframes hint-bounce {
    0%, 100% { transform: translateX(-50%) translateY(0);     opacity: 0.6; }
    50%       { transform: translateX(-50%) translateY(10px);  opacity: 1;   }
}

@media (max-width: 768px) {
    .hero-content {
        padding: 1.5rem;
        align-items: center;
        justify-content: flex-end;
        padding-bottom: 5rem;
        text-align: center;
    }
    .hero-subtitle { max-width: 100%; }
}
</style>

<script>
/* ── Parallax ─────────────────────────────────────────────── */
(function () {
    var img     = document.getElementById('HeroImage');
    var section = document.getElementById('HeroSection');
    var hint    = document.getElementById('HeroScrollHint');
    if (!img || !section) return;

    var ticking = false;

    function onScroll() {
        if (!ticking) {
            requestAnimationFrame(update);
            ticking = true;
        }
    }

    function update() {
        ticking = false;
        var scrolled = window.scrollY;
        var sectionH = section.offsetHeight;

        /* Parallax: image moves at 40% of scroll speed */
        var shift = scrolled * 0.40;
        img.style.transform = 'scale(1.07) translateY(calc(' + shift + 'px - 1%))';
        img.classList.add('parallax-active');

        /* Fade out scroll hint */
        if (hint) {
            hint.style.opacity = scrolled > 80 ? '0' : '1';
        }
    }

    window.addEventListener('scroll', onScroll, { passive: true });
    update(); /* run once on load */
})();
</script>

{% schema %}
{
  "name": "هيرو",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "إظهار نص فوق الصورة",
      "default": false
    },
    {
      "type": "text",
      "id": "title",
      "label": "العنوان الرئيسي",
      "default": "الجديد في Shop Five"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "النص الفرعي",
      "default": "اكتشف أحدث التصاميم لهذا الموسم"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "نص الزر"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "رابط الزر"
    }
  ],
  "presets": [
    {
      "name": "هيرو"
    }
  ]
}
{% endschema %}
