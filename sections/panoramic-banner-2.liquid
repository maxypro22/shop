<section class="pb-wrap">

  {%- if section.settings.image != blank -%}
    {%- assign pb_src = section.settings.image | image_url: width: 1920 -%}
    {%- assign pb_src_mobile = section.settings.image | image_url: width: 900 -%}
  {%- else -%}
    {%- assign pb_src = 'pb-studio-a.jpg' | asset_url -%}
    {%- assign pb_src_mobile = pb_src -%}
  {%- endif -%}

  <picture>
    <source media="(max-width: 640px)" srcset="{{ pb_src_mobile }}">
    <img src="{{ pb_src }}" alt="{{ section.settings.title | escape }}" class="pb-img" loading="lazy">
  </picture>

  <div class="pb-vignette pb-vignette--cool"></div>
  <div class="pb-grain"></div>

  <div class="pb-content">
    {%- if section.settings.eyebrow != blank -%}
      <span class="pb-eyebrow">{{ section.settings.eyebrow }}</span>
    {%- endif -%}
    <div class="pb-divider">
      <span class="pb-line"></span>
      <span class="pb-diamond"></span>
      <span class="pb-line"></span>
    </div>
    <h2 class="pb-title">{{ section.settings.title }}</h2>
    {%- if section.settings.subtitle != blank -%}
      <p class="pb-subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}
    {%- if section.settings.btn_label != blank and section.settings.btn_url != blank -%}
      <a href="{{ section.settings.btn_url }}" class="pb-btn">
        {{ section.settings.btn_label }} <i data-lucide="arrow-left"></i>
      </a>
    {%- endif -%}
  </div>

</section>

{% schema %}
{
  "name": "بانر بانوراما ٢",
  "settings": [
    { "type": "image_picker", "id": "image", "label": "الصورة" },
    { "type": "text", "id": "eyebrow", "label": "النص فوق العنوان", "default": "SHOP FIVE" },
    { "type": "text", "id": "title", "label": "العنوان الرئيسي", "default": "أناقة بلا حدود" },
    { "type": "text", "id": "subtitle", "label": "النص الفرعي", "default": "كل ما تحتاجه من أزياء وإكسسوارات في مكان واحد" },
    { "type": "text", "id": "btn_label", "label": "نص الزر" },
    { "type": "url", "id": "btn_url", "label": "رابط الزر" }
  ],
  "presets": [{ "name": "بانر بانوراما ٢" }]
}
{% endschema %}
