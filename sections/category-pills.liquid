<div class="main-container" style="padding-bottom: 0;">
    <div class="pills-wrapper">

        <!-- Right arrow (scroll back / go right) -->
        <button class="pills-arrow pills-arrow-right" id="PillsRight" aria-label="السابق">
            <i data-lucide="chevron-right"></i>
        </button>

        <section class="category-pills" id="CatPillsTrack" style="padding-bottom: 1rem;">
            <a href="/collections/all" class="pill {% if request.path == '/collections/all' or request.path == '/' %}active{% endif %}" style="text-decoration: none;">الكل</a>
            <a href="/collections/العطور" class="pill {% if request.path contains 'العطور' %}active{% endif %}" style="text-decoration: none;">العطور</a>
            <a href="/collections/shoes" class="pill {% if request.path contains 'shoes' %}active{% endif %}" style="text-decoration: none;">shoes</a>
            <a href="/collections/سليبر-بحر" class="pill {% if request.path contains 'سليبر-بحر' %}active{% endif %}" style="text-decoration: none;">سليبر بحر</a>
            <a href="/collections/oversized" class="pill {% if request.path contains 'oversized' %}active{% endif %}" style="text-decoration: none;">oversized</a>
            <a href="/collections/t-shirt" class="pill {% if request.path contains 't-shirt' %}active{% endif %}" style="text-decoration: none;">t-shirt</a>
            <a href="/collections/قمصان-رجالية" class="pill {% if request.path contains 'قمصان-رجالية' %}active{% endif %}" style="text-decoration: none;">قمصان رجالية</a>

            {% for collection in collections %}
                {% assign handle = collection.handle %}
                {% if handle != 'frontpage' and handle != 'all' and handle != 'العطور' and handle != 'shoes' and handle != 'سليبر-بحر' and handle != 'oversized' and handle != 't-shirt' and handle != 'قمصان-رجالية' %}
                    <a href="{{ collection.url }}" class="pill {% if request.path == collection.url %}active{% endif %}" style="text-decoration: none;">{{ collection.title }}</a>
                {% endif %}
            {% endfor %}
        </section>

        <!-- Left arrow (scroll to see more) -->
        <button class="pills-arrow pills-arrow-left" id="PillsLeft" aria-label="التالي">
            <i data-lucide="chevron-left"></i>
        </button>

    </div>
</div>

<!-- Full Categories Modal -->
<div id="CategoriesModal" class="categories-modal" onclick="if(event.target === this) closeCategoriesModal()">
    <div class="modal-content">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
            <h2 style="font-size: 1.5rem; color: var(--text-dark);">تصفح جميع الأقسام</h2>
            <button class="close-modal" onclick="closeCategoriesModal()" style="border:none; background:none; cursor:pointer; padding:0.5rem; color:var(--text-muted);">
                <i data-lucide="x" style="width:24px; height:24px;"></i>
            </button>
        </div>
        <div class="modal-grid" style="display: flex; flex-wrap: wrap; gap: 0.75rem;">
            <a href="/collections/all" class="pill {% if request.path == '/collections/all' or request.path == '/' %}active{% endif %}" style="text-decoration: none;">الكل</a>
            <a href="/collections/العطور" class="pill {% if request.path contains 'العطور' %}active{% endif %}" style="text-decoration: none;">العطور</a>
            <a href="/collections/shoes" class="pill {% if request.path contains 'shoes' %}active{% endif %}" style="text-decoration: none;">shoes</a>
            <a href="/collections/سليبر-بحر" class="pill {% if request.path contains 'سليبر-بحر' %}active{% endif %}" style="text-decoration: none;">سليبر بحر</a>
            <a href="/collections/oversized" class="pill {% if request.path contains 'oversized' %}active{% endif %}" style="text-decoration: none;">oversized</a>
            <a href="/collections/t-shirt" class="pill {% if request.path contains 't-shirt' %}active{% endif %}" style="text-decoration: none;">t-shirt</a>
            <a href="/collections/قمصان-رجالية" class="pill {% if request.path contains 'قمصان-رجالية' %}active{% endif %}" style="text-decoration: none;">قمصان رجالية</a>
            {% for collection in collections %}
                {% assign handle = collection.handle %}
                {% if handle != 'frontpage' and handle != 'all' and handle != 'العطور' and handle != 'shoes' and handle != 'سليبر-بحر' and handle != 'oversized' and handle != 't-shirt' and handle != 'قمصان-رجالية' %}
                    <a href="{{ collection.url }}" class="pill {% if request.path == collection.url %}active{% endif %}" style="text-decoration: none;">{{ collection.title }}</a>
                {% endif %}
            {% endfor %}
        </div>
    </div>
</div>

<script>
(function () {
    var track    = document.getElementById('CatPillsTrack');
    var btnLeft  = document.getElementById('PillsLeft');
    var btnRight = document.getElementById('PillsRight');
    if (!track || !btnLeft || !btnRight) return;

    var STEP      = 280;   // px per arrow click
    var SPEED     = 1;     // px per frame for auto-scroll (~60px/s)
    var paused    = false;
    var resumeTimer = null;
    var halfWidth = 0;
    var accum     = 0;     // sub-pixel accumulator

    /* ── Clone pills for seamless infinite loop ─────────────── */
    Array.from(track.children).forEach(function (pill) {
        track.appendChild(pill.cloneNode(true));
    });

    /* ── Auto-scroll loop ────────────────────────────────────── */
    function tick() {
        if (!paused) {
            accum += SPEED;
            if (accum >= 1) {
                var step = Math.floor(accum);
                accum -= step;
                track.scrollLeft -= step;   /* RTL: negative = scroll left = show more */
                /* seamless reset: jumped past the original half */
                if (halfWidth > 0 && Math.abs(track.scrollLeft) >= halfWidth) {
                    track.scrollLeft = 0;
                    accum = 0;
                }
            }
        }
        requestAnimationFrame(tick);
    }

    /* ── Pause / resume helpers ──────────────────────────────── */
    function pause(resumeAfterMs) {
        paused = true;
        clearTimeout(resumeTimer);
        if (resumeAfterMs) {
            resumeTimer = setTimeout(function () { paused = false; }, resumeAfterMs);
        }
    }
    function resume() { paused = false; }

    /* ── Arrow buttons ───────────────────────────────────────── */
    btnLeft.addEventListener('click', function () {
        track.scrollBy({ left: -STEP, behavior: 'smooth' });
        pause(3500);
    });
    btnRight.addEventListener('click', function () {
        track.scrollBy({ left: STEP, behavior: 'smooth' });
        pause(3500);
    });

    /* ── Hover pause ─────────────────────────────────────────── */
    track.addEventListener('mouseenter', function () { pause(); });
    track.addEventListener('mouseleave', resume);

    /* ── Mouse drag ──────────────────────────────────────────── */
    var isDragging = false, startX = 0, startScroll = 0;
    track.addEventListener('mousedown', function (e) {
        isDragging = true;
        startX = e.pageX;
        startScroll = track.scrollLeft;
        track.style.cursor = 'grabbing';
        pause();
    });
    document.addEventListener('mouseup', function () {
        if (!isDragging) return;
        isDragging = false;
        track.style.cursor = '';
        pause(2500);
    });
    track.addEventListener('mousemove', function (e) {
        if (!isDragging) return;
        track.scrollLeft = startScroll - (e.pageX - startX);
    });

    /* ── Touch ───────────────────────────────────────────────── */
    track.addEventListener('touchstart', function () { pause(); }, { passive: true });
    track.addEventListener('touchend',   function () { pause(2500); }, { passive: true });

    /* ── Both arrows always visible in loop mode ─────────────── */
    btnLeft.classList.add('visible');
    btnRight.classList.add('visible');

    /* ── Start after layout settles ─────────────────────────── */
    setTimeout(function () {
        halfWidth = track.scrollWidth / 2;
        requestAnimationFrame(tick);
    }, 300);
})();
</script>

{% schema %}
{
  "name": "Category Pills",
  "settings": []
}
{% endschema %}
