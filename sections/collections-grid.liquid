<section class="cg-section">

  <div class="cg-header main-container">
    <div class="cg-header-text">
      <span class="cg-eyebrow">SHOP FIVE</span>
      <h2 class="cg-title">{{ section.settings.title | default: 'كل الكولكشنات' }}</h2>
    </div>
    <div class="cg-arrows">
      <button class="cg-arrow" id="CgArrowRight" aria-label="السابق">
        <i data-lucide="chevron-right"></i>
      </button>
      <button class="cg-arrow" id="CgArrowLeft" aria-label="التالي">
        <i data-lucide="chevron-left"></i>
      </button>
    </div>
  </div>

  <div class="cg-track-wrap">
    <div class="cg-track" id="CgTrack">

      {%- for i in (1..8) -%}
        {%- assign col_key  = 'col_'  | append: i -%}
        {%- assign img_key  = 'img_'  | append: i -%}
        {%- assign tall_key = 'tall_' | append: i -%}
        {%- assign coll     = collections[section.settings[col_key]] -%}
        {%- assign card_img = section.settings[img_key] | default: coll.image -%}
        {%- if coll != blank or card_img != blank -%}
          {%- assign card_name = coll.title | default: '' -%}
          {%- assign card_url  = coll.url   | default: '#' -%}
          {%- assign is_tall   = section.settings[tall_key] -%}
          <a href="{{ card_url }}" class="cg-card{% if is_tall %} cg-card--tall{% endif %}">
            {%- if card_img != blank -%}
              <img
                src="{{ card_img | image_url: width: 550 }}"
                alt="{{ card_name | escape }}"
                class="cg-img"
                loading="lazy"
              >
            {%- else -%}
              <div class="cg-img-ph"></div>
            {%- endif -%}
            <div class="cg-overlay">
              <span class="cg-name">{{ card_name }}</span>
            </div>
          </a>
        {%- endif -%}
      {%- endfor -%}

    </div>
  </div>

</section>

<style>
.cg-section {
    padding: 4.5rem 0 3rem;
    background: var(--bg-main);
    overflow: hidden;
}
.cg-header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    direction: rtl;
    margin-bottom: 1.75rem;
}
.cg-eyebrow {
    display: block;
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: #c9a96e;
    margin-bottom: 0.4rem;
}
.cg-title {
    font-size: 2.25rem;
    font-weight: 900;
    color: var(--text-dark);
    line-height: 1.15;
}
.cg-arrows {
    display: flex;
    gap: 0.45rem;
    padding-bottom: 0.25rem;
}
.cg-arrow {
    width: 46px;
    height: 46px;
    border-radius: 50%;
    border: 1.5px solid rgba(0,0,0,0.11);
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--text-dark);
    transition: background 0.22s ease, color 0.22s ease,
                transform 0.22s cubic-bezier(0.16,1,0.3,1), border-color 0.22s;
    box-shadow: 0 2px 12px rgba(0,0,0,0.07);
    flex-shrink: 0;
}
.cg-arrow:hover {
    background: var(--text-dark);
    color: #fff;
    border-color: var(--text-dark);
    transform: scale(1.1);
}
.cg-arrow i { width: 18px; height: 18px; pointer-events: none; }

.cg-track-wrap { overflow: hidden; }
.cg-track {
    display: grid;
    grid-template-rows: 225px 225px;
    grid-auto-flow: column;
    grid-auto-columns: 200px;
    gap: 7px;
    padding: 0 2rem 8px;
    overflow-x: auto;
    scrollbar-width: none;
    scroll-behavior: smooth;
    cursor: grab;
    -webkit-overflow-scrolling: touch;
}
.cg-track:active { cursor: grabbing; }
.cg-track::-webkit-scrollbar { display: none; }

.cg-card {
    position: relative;
    border-radius: 13px;
    overflow: hidden;
    display: block;
    text-decoration: none;
    background: #ddd;
    transition: box-shadow 0.35s ease;
}
.cg-card--tall { grid-row: span 2; }
.cg-card:hover { box-shadow: 0 12px 36px rgba(0,0,0,0.2); }

.cg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.68);
    transition: transform 0.6s cubic-bezier(0.16,1,0.3,1), filter 0.45s ease;
}
.cg-img-ph {
    width: 100%;
    height: 100%;
    background: linear-gradient(145deg, #d8d8d8, #ebebeb);
}
.cg-card:hover .cg-img {
    transform: scale(1.08);
    filter: brightness(0.9);
}
.cg-overlay {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    padding: 1rem;
    direction: rtl;
    background: linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.04) 50%, transparent 100%);
}
.cg-name {
    color: #fff;
    font-size: 0.88rem;
    font-weight: 800;
    line-height: 1.3;
    text-shadow: 0 1px 10px rgba(0,0,0,0.4);
    transform: translateY(6px);
    opacity: 0.72;
    transition: transform 0.35s cubic-bezier(0.16,1,0.3,1), opacity 0.3s ease;
}
.cg-card:hover .cg-name { transform: translateY(0); opacity: 1; }

@media (max-width: 768px) {
    .cg-section { padding: 3rem 0 2rem; }
    .cg-track {
        grid-template-rows: 160px 160px;
        grid-auto-columns: 148px;
        gap: 5px;
        padding: 0 1rem 6px;
    }
    .cg-title { font-size: 1.55rem; }
    .cg-header { padding: 0 1rem; margin-bottom: 1.25rem; }
    .cg-arrow { width: 38px; height: 38px; }
}
</style>

