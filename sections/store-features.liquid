<div class="store-features-section">
    <div class="main-container">
        <div class="features-header">
            <h2>وعودنا لك</h2>
            <p>نلتزم بتقديم أفضل تجربة تسوق</p>
        </div>
        <div class="features-grid">

            <!-- Card 1: Returns -->
            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/>
                        <path d="M3 3v5h5"/>
                    </svg>
                </div>
                <h3>استرجاع 14 يوم</h3>
                <p>تسوق بكل ثقة، سياسة استرجاع مرنة وسهلة</p>
            </div>

            <!-- Card 2: Delivery -->
            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 17H3a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11a2 2 0 0 1 2 2v3"/>
                        <rect x="9" y="11" width="14" height="10" rx="2"/>
                        <circle cx="12" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
                    </svg>
                </div>
                <h3>توصيل 4 أيام</h3>
                <p>توصيل سريع ومضمون لباب بيتك أينما كنت</p>
            </div>

            <!-- Card 3: Quality -->
            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
                        <path d="m9 12 2 2 4-4"/>
                    </svg>
                </div>
                <h3>جودة ممتازة</h3>
                <p>منتجات أصلية ومضمونة 100% مطابقة للصور</p>
            </div>

            <!-- Card 4: 24/7 Support -->
            <div class="feature-card">
                <div class="feature-icon">
                    <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
                        <path d="M12 8v4"/><path d="M12 16h.01"/>
                    </svg>
                </div>
                <h3>خدمة عملاء 24/7</h3>
                <p>Available 24/7 — فريقنا دائماً هنا لمساعدتك</p>
            </div>

        </div>
    </div>
</div>

<style>
.store-features-section {
    padding: 5rem 0;
    background: var(--bg-card);
}

.features-header {
    text-align: center;
    margin-bottom: 3.5rem;
}
.features-header h2 {
    font-size: 2.4rem;
    color: var(--text-dark);
    font-weight: 900;
    margin-bottom: 0.5rem;
}
.features-header p {
    color: var(--text-muted);
    font-size: 1.05rem;
}

/* ── 4-col grid on desktop ─────────────────────────────────── */
.features-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    max-width: 1280px;
    margin: 0 auto;
}

/* ── Card ──────────────────────────────────────────────────── */
.feature-card {
    background: var(--bg-main);
    padding: 2.5rem 1.75rem;
    border-radius: 1.5rem;
    text-align: center;
    border: 1px solid transparent;
    position: relative;
    overflow: hidden;
    transition: transform 0.38s cubic-bezier(0.16,1,0.3,1),
                box-shadow 0.38s cubic-bezier(0.16,1,0.3,1),
                border-color 0.3s ease;
    box-shadow: 0 2px 12px rgba(0,0,0,0.04);
}

/* Accent top line */
.feature-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 3px;
    background: linear-gradient(90deg, var(--primary), #a29bfe);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.38s cubic-bezier(0.16,1,0.3,1);
    border-radius: 3px 3px 0 0;
}

.feature-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 24px 48px rgba(0,0,0,0.10);
    border-color: rgba(108,92,231,0.12);
}
.feature-card:hover::before {
    transform: scaleX(1);
    transform-origin: left;
}

/* ── Icon circle ───────────────────────────────────────────── */
.feature-icon {
    width: 76px;
    height: 76px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    background: linear-gradient(135deg, rgba(108,92,231,0.08), rgba(162,155,254,0.12));
    border: 1.5px solid rgba(108,92,231,0.15);
    color: var(--primary, #6C5CE7);
    transition: all 0.38s cubic-bezier(0.16,1,0.3,1);
}
.feature-card:hover .feature-icon {
    background: linear-gradient(135deg, var(--primary, #6C5CE7), #a29bfe);
    border-color: transparent;
    color: #fff;
    transform: scale(1.08) rotate(-6deg);
    box-shadow: 0 8px 24px rgba(108,92,231,0.35);
}

.feature-card h3 {
    font-size: 1.2rem;
    font-weight: 800;
    color: var(--text-dark);
    margin-bottom: 0.65rem;
    line-height: 1.3;
}
.feature-card p {
    color: var(--text-muted);
    font-size: 0.9rem;
    line-height: 1.65;
}

/* ── Responsive ────────────────────────────────────────────── */
@media (max-width: 1024px) {
    .features-grid { grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
}
@media (max-width: 480px) {
    /* 2×2 on phone */
    .features-grid { grid-template-columns: repeat(2, 1fr); gap: 0.85rem; }
    .feature-card { padding: 1.75rem 1.1rem; }
    .feature-icon { width: 60px; height: 60px; }
    .feature-card h3 { font-size: 1rem; }
    .feature-card p { font-size: 0.82rem; }
}
</style>

{% schema %}
{
  "name": "وعود المتجر",
  "presets": [{ "name": "وعود المتجر" }]
}
{% endschema %}
